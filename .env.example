# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# NODE_ENV: Set to 'production' for production deployment
NODE_ENV=production

# PORT: The port your application will run on (Render provides this automatically)
PORT=10000

# MONGODB_URI: MongoDB connection string
# Get from: https://cloud.mongodb.com
# Example: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_connection_string_here

# MONGODB_DB_NAME: Database name (optional, defaults to 'interview_prep')
MONGODB_DB_NAME=interview_prep

# JWT_SECRET: Secret key for JWT tokens (change this to a random string)
JWT_SECRET=your_secure_random_jwt_secret_key_here
